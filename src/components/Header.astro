---
const navItems = [
  { label: "Services", href: "/services" },
  { label: "Portfolio", href: "/previous-work" },
  { label: "About", href: "/about" },
  { label: "Free Estimate", href: "/estimate" },
];

import { phoneHref } from "../siteConfig";
import Horse from "./Horse.astro";
---

<header class="sticky top-0 bg-white shadow-sm z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center">
      <a
        href="/"
        class="flex items-center hover:text-indigo-600 transition-colors"
      >
        <Horse class="w-24 h-auto" />
        <span class="text-2xl font-header tracking-tight font-bold -ml-4">
          Saddle & Spur Construction
        </span>
      </a>

      <nav class="hidden md:flex space-x-8">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="text-gray-700 hover:text-indigo-700 transition"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center space-x-4">
        <a
          href={`tel:${phoneHref}`}
          class="hidden sm:inline-block px-4 py-2 bg-indigo-700 text-white rounded hover:bg-indigo-800 transition"
        >
          Call Now
        </a>
        <button class="md:hidden p-2 rounded hover:bg-gray-100">
          <span class="text-2xl">☰</span>
        </button>
      </div>
    </div>
  </div>
</header>
