---
import type { PortfolioMarkup } from "../../data/portfolio";

type Props = {
    highlights: string[];
    className?: string;
    overview: PortfolioMarkup["overview"];
};

const { highlights, className, overview: o } = Astro.props;
if (!highlights?.length) return null;
---

<section class:list={["mx-auto max-w-5xl", className]}>
    <div class="grid gap-12 lg:grid-cols-2">
        <div>
            <h2 class="text-2xl font-semibold mb-4">Overview</h2>
            <div class="grid gap-4 sm:grid-cols-2 pt-6">
                <div class="flex gap-3">
                    <i class="fa-solid fa-location-dot text-indigo-600 mt-1"
                    ></i>
                    <div>
                        <p class="text-sm text-gray-500">Location</p>
                        <p class="font-semibold">{o.locationLabel}</p>
                    </div>
                </div>

                <div class="flex gap-3">
                    <i class="fa-solid fa-calendar text-indigo-600 mt-1"></i>
                    <div>
                        <p class="text-sm text-gray-500">Timeline</p>
                        <p class="font-semibold">{o.timelineLabel}</p>
                    </div>
                </div>
                <div class="flex gap-3">
                    <i
                        class="fa-solid fa-screwdriver-wrench text-indigo-600 mt-1"
                    ></i>
                    <div>
                        <p class="text-sm text-gray-500">Scope</p>
                        <p class="font-semibold">{o.scopeLabel}</p>
                    </div>
                </div>
                <div class="flex gap-3">
                    <i class="fa-solid fa-calendar-check text-indigo-600 mt-1"
                    ></i>
                    <div>
                        <p class="text-sm text-gray-500">Completed</p>
                        <p class="font-semibold">{o.completedLabel}</p>
                    </div>
                </div>
            </div>
        </div>

        <div>
            <h2 class="text-2xl font-semibold mb-4">Highlights</h2>
            <ul class="space-y-4 pt-6">
                {
                    highlights.map((h) => (
                        <li class="flex items-start gap-3">
                            <i class="fa-solid fa-circle-check text-indigo-600 mt-1" />
                            <span class="text-gray-700">{h}</span>
                        </li>
                    ))
                }
            </ul>
        </div>
    </div>
</section>
