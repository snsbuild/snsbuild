---
// src/components/portfolio/PortfolioGallery.astro
import type { PortfolioMarkup } from "../../data/portfolio";

type Props = { gallery: PortfolioMarkup["gallery"] };
const { gallery } = Astro.props;
---

<section class="container section" aria-labelledby="gallery">
    <h2 id="gallery">Gallery</h2>
    {gallery.intro && <p class="muted">{gallery.intro}</p>}

    <div class="gallery">
        {
            gallery.images.map((img) => (
                <figure class="item">
                    <img
                        src={img.src}
                        alt={img.alt}
                        width={img.width ?? 1200}
                        height={img.height ?? 800}
                        loading="lazy"
                    />
                    {img.caption && <figcaption>{img.caption}</figcaption>}
                </figure>
            ))
        }
    </div>
</section>

<style>
    .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 clamp(16px, 3vw, 28px);
    }
    .section {
        padding: 26px 0;
        border-top: 1px solid rgba(0, 0, 0, 0.12);
    }
    h2 {
        margin: 0 0 10px;
        font-size: clamp(20px, 2.2vw, 28px);
    }
    .muted {
        color: rgba(0, 0, 0, 0.65);
    }
    .gallery {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin-top: 12px;
    }
    @media (max-width: 920px) {
        .gallery {
            grid-template-columns: 1fr 1fr;
        }
    }
    @media (max-width: 560px) {
        .gallery {
            grid-template-columns: 1fr;
        }
    }
    .item {
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 14px;
        overflow: hidden;
        background: #fff;
        margin: 0;
    }
    img {
        width: 100%;
        height: auto;
        display: block;
    }
    figcaption {
        padding: 10px 12px;
        font-size: 0.95rem;
        color: rgba(0, 0, 0, 0.65);
    }
</style>
