---
import type { ServiceEntity } from "../../types/entity-types";

type Props = { related: ServiceEntity[] };
const { related } = Astro.props;
---

<section
  class="max-w-280 mx-auto px-[clamp(16px,3vw,28px)] py-16 border-t border-black/12"
  aria-labelledby="related"
>
  <h2 id="related" class="my-4 pb-4 text-[clamp(20px,2.2vw,28px)]">
    Related Services
  </h2>
  <div class="grid grid-cols-1 min-[920px]:grid-cols-2 gap-5.5 mt-3">
    {
      related.map((r) => (
        <article class="border border-black/12 rounded-2xl bg-white p-4.5">
          <h3 class="mt-0 text-2xl font-semibold mb-1.5">{r.name}</h3>
          {r.description && (
            <p class="mt-0 mb-2.5 text-[0.95rem] text-black/65">
              {r.description}
            </p>
          )}
          <a
            class="inline-flex items-center justify-center px-3.5 py-3  border rounded border-indigo-600 text-indigo-600 bg-white no-underline font-semibold transition-colors duration-150 hover:bg-indigo-600 hover:text-white"
            href={r.path}
          >
            View service
          </a>
        </article>
      ))
    }
  </div>
</section>
