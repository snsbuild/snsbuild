---
const { story } = Astro.props;
---

<section aria-labelledby="story" class="py-6">
  <div class="mx-auto max-w-280 px-6 lg:px-7">
    <div class="mb-4 flex items-end justify-between gap-4 py-6">
      <h2
        id="story"
        class="text-[clamp(20px,2.2vw,28px)] font-semibold tracking-tight text-gray-900"
      >
        The Story
      </h2>
    </div>

    {/* Row 1: Narrative cards */}
    <div class="grid grid-cols-1 gap-5.5 lg:grid-cols-2">
      <article class="rounded-2xl border border-black/10 bg-white p-4.5">
        <h3 class="mb-2 flex items-center gap-2 font-semibold text-gray-900">
          <i class="fa-solid fa-house-circle-check text-indigo-600"></i>
          What the homeowner wanted
        </h3>
        <p class="text-black/65 leading-relaxed">
          {story.homeownerWanted}
        </p>
      </article>

      <article class="rounded-2xl border border-black/10 bg-white p-4.5">
        <h3 class="mb-2 flex items-center gap-2 font-semibold text-gray-900">
          <i class="fa-solid fa-compass-drafting text-indigo-600"></i>
          Our plan
        </h3>
        <p class="text-black/65 leading-relaxed">{story.plan}</p>
      </article>
    </div>

    {/* Row 2: Process + Results */}
    <div class="mt-3 grid grid-cols-1 gap-5.5 lg:grid-cols-2">
      <article class="rounded-2xl border border-black/10 bg-white p-4.5">
        <h3 class="mb-3 flex items-center gap-2 font-semibold text-gray-900">
          <i class="fa-solid fa-list-check text-indigo-600"></i>
          Build steps (high level)
        </h3>

        <ol class="space-y-3">
          {
            story.buildSteps.map((s) => (
              <li class="flex items-start gap-3">
                <i class="fa-solid fa-circle-check text-indigo-600 mt-1 text-xs" />
                <span class="text-gray-700">{s}</span>
              </li>
            ))
          }
        </ol>
      </article>

      <article class="rounded-2xl border border-black/10 bg-white p-4.5">
        <h3 class="mb-3 flex items-center gap-2 font-semibold text-gray-900">
          <i class="fa-solid fa-chart-line text-indigo-600"></i>
          Results
        </h3>

        <ul class="space-y-3">
          {
            story.results.map((r) => (
              <li class="flex items-start gap-3">
                <i class="fa-solid fa-sparkles text-indigo-600 mt-1 text-xs" />
                <span class="text-gray-700">{r}</span>
              </li>
            ))
          }
        </ul>
      </article>
    </div>
  </div>
</section>
