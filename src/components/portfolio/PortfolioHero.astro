---
// src/components/portfolio/PortfolioHero.astro
import type { PortfolioEntry, PortfolioMarkup } from "../../data/portfolio";

type Props = { page: PortfolioEntry; markup: PortfolioMarkup["hero"] };
const { page, markup } = Astro.props;

const heroImg = page.ogImage?.src ?? page.images?.[0]?.src;
const heroAlt = page.ogImage?.alt ?? page.images?.[0]?.alt ?? page.title;
---

<section class="relative bg-white">
    <div class="mx-auto max-w-7xl lg:grid lg:grid-cols-12 lg:gap-x-8 lg:px-8">
        <div
            class="px-6 pt-10 pb-24 sm:pb-32 lg:col-span-7 lg:px-0 lg:pt-40 lg:pb-48 xl:col-span-6"
        >
            <div class="mx-auto max-w-lg lg:mx-0">
                {markup.kicker && <p class="kicker" set:html={markup.kicker} />}
                <h1
                    class="mt-24 text-5xl font-semibold tracking-tight text-pretty text-gray-900 sm:mt-10 sm:text-7xl"
                >
                    {page.project.name}
                </h1>
                <p
                    class="mt-8 text-lg font-medium text-pretty text-gray-500 sm:text-xl/8"
                >
                    {page.description}
                </p>
                <div class="mt-10 flex items-center gap-x-6">
                    <a
                        href={markup.primaryCta.href}
                        class="rounded-md bg-indigo-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600"
                        >{markup.primaryCta.label}</a
                    >
                    <a
                        href={markup.secondaryCta?.href}
                        class="text-sm/6 font-semibold text-gray-900"
                        >{markup.secondaryCta?.label}<span aria-hidden="true"
                            >→</span
                        ></a
                    >
                </div>
            </div>
        </div>
        <div
            class="relative lg:col-span-5 lg:-mr-8 xl:absolute xl:inset-0 xl:left-1/2 xl:mr-0"
        >
            <img
                src={heroImg}
                alt={heroAlt}
                class="aspect-3/2 w-full bg-gray-50 object-cover lg:absolute lg:inset-0 lg:aspect-auto lg:h-full"
            />
        </div>
    </div>
</section>
