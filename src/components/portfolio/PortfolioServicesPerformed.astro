---
import type { ServicePerformedItem } from "../../data/portfolio";

type Props = {
  eyebrow?: string;
  title?: string;
  intro?: string;
  items: ServicePerformedItem[];
  columns?: 1 | 2;
  showDescriptionFallback?: boolean;
};

const {
  eyebrow = "What we did",
  title = "Services performed on this job",
  intro,
  items,
  columns = 2,
  showDescriptionFallback = false,
} = Astro.props;

const gridCols = columns === 1 ? "sm:grid-cols-1" : "sm:grid-cols-2";
---

<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div
      class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-12 lg:mx-0 lg:max-w-none lg:grid-cols-5"
    >
      {/* Left column */}
      <div class="lg:col-span-2">
        <p class="text-sm font-semibold text-indigo-600">{eyebrow}</p>
        <h2
          class="mt-2 text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl"
        >
          {title}
        </h2>

        {intro && <p class="mt-6 text-base leading-7 text-gray-700">{intro}</p>}
      </div>

      {/* Right column list */}
      <dl
        class={`lg:col-span-3 grid grid-cols-1 gap-x-8 gap-y-8 text-base leading-7 text-gray-600 ${gridCols} lg:gap-y-10`}
      >
        {
          items.map((it) => (
            <div class="relative pl-11">
              <dt class="font-semibold text-gray-900">
                <i
                  class={`${it.icon} absolute left-0 top-1 text-indigo-600`}
                  aria-hidden="true"
                />
                {it.name}
              </dt>

              {(it.description || showDescriptionFallback) && (
                <dd class="mt-2 text-sm leading-6 text-gray-600">
                  {it.description ?? "Details available upon request."}
                </dd>
              )}
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</section>
