---
// src/components/portfolio/PortfolioCta.astro
import type { PortfolioMarkup } from "../../data/portfolio";

type Props = { cta: PortfolioMarkup["cta"] };
const { cta } = Astro.props;
---

<section class="container section" aria-labelledby="cta">
    <div class="cta" id="cta">
        <div>
            <h2 style="margin: 0 0 6px">{cta.heading}</h2>
            <p class="muted" style="margin: 0">{cta.body}</p>
        </div>
        <div class="btns">
            <a class="btn primary" href={cta.primaryCta.href}
                >{cta.primaryCta.label}</a
            >
            {
                cta.secondaryCta && (
                    <a class="btn ghost" href={cta.secondaryCta.href}>
                        {cta.secondaryCta.label}
                    </a>
                )
            }
        </div>
    </div>
</section>

<style>
    .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 clamp(16px, 3vw, 28px);
    }
    .section {
        padding: 26px 0;
        border-top: 1px solid rgba(0, 0, 0, 0.12);
    }
    .cta {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 18px;
        align-items: center;
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 16px;
        padding: 18px;
        background: #111;
        color: #fff;
    }
    @media (max-width: 920px) {
        .cta {
            grid-template-columns: 1fr;
        }
    }
    .muted {
        color: rgba(255, 255, 255, 0.78);
    }
    .btns {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }
    @media (max-width: 920px) {
        .btns {
            justify-content: flex-start;
        }
    }
    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 14px;
        border-radius: 999px;
        border: 1px solid #fff;
        text-decoration: none;
        font-weight: 600;
    }
    .btn.primary {
        background: #fff;
        color: #111;
        border-color: #fff;
    }
    .btn.ghost {
        background: transparent;
        color: #fff;
    }
</style>
