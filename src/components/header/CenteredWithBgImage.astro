<script src="/js/replaceme.min.js" defer></script>

<script>
    declare global {
        interface Window {
            ReplaceMe: new (element: HTMLElement | null, options: any) => void;
        }
    }

    const options = {
        animation: "animated flipInX", // Animation class or classes
        speed: 3000, // Delay between each phrase in milliseconds
        separator: ",", // Phrases separator
        hoverStop: true, // Stop rotator on phrase hover
        clickChange: false, // Change phrase on click
        loopCount: "infinite", // Loop Count - 'infinite' or number
        autoRun: true, // Run rotator automatically
        onInit: false, // Function
        onChange: false, // Function
        onComplete: false, // Function
    };

    window.addEventListener("DOMContentLoaded", () => {
        const replaceEl = document.getElementById("replace-service-list");
        new window.ReplaceMe(replaceEl, options);
    });
</script>
