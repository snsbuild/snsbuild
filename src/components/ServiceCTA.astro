---
type Category = "interior" | "expansion" | "outdoor";
type Variant = "light" | "dark";

interface Props {
    className?: string;
    category?: Category;
    headline?: string;
    ctaSubheader?: string;
    ctaOne?: string;
    ctaTwo?: string;
    ctaOneHref?: string;
    ctaTwoHref?: string;
    variant?: Variant;
}

const {
    className,
    // "interior" | "expansion" | "outdoor"
    category = "interior",

    // optional overrides
    headline,
    ctaSubheader,
    ctaOne,
    ctaTwo,
    ctaOneHref,
    ctaTwoHref,

    // optional: force light/dark regardless of category
    variant, // "light" | "dark"
} = Astro.props as Props;

const presets = {
    interior: {
        bg: "bg-gray-900",
        heading: "text-white",
        sub: "text-gray-200",
        primaryBtn: "bg-white text-gray-900 hover:bg-gray-200",
        secondaryLink: "text-white hover:text-gray-300",
        defaultHeadline: "Ready to refresh your home?",
        defaultSub:
            "Kitchen, bath, flooring, and whole-home remodels—planned well and built to last.",
        defaultCtaOne: "Request an Estimate",
        defaultCtaOneHref: "/contact",
        defaultCtaTwo: "View Interior Services",
        defaultCtaTwoHref: "/services#interior",
    },

    expansion: {
        bg: "bg-indigo-950",
        heading: "text-white",
        sub: "text-indigo-100",
        primaryBtn: "bg-white text-indigo-950 hover:bg-indigo-100",
        secondaryLink: "text-white hover:text-indigo-200",
        defaultHeadline: "Need more space—without moving?",
        defaultSub:
            "ADUs, additions, conversions, and structural work across Seattle & King County.",
        defaultCtaOne: "Talk Through Your Plans",
        defaultCtaOneHref: "/contact",
        defaultCtaTwo: "Explore Expansion Options",
        defaultCtaTwoHref: "/services#expansion",
    },

    outdoor: {
        bg: "bg-emerald-950",
        heading: "text-white",
        sub: "text-emerald-100",
        primaryBtn: "bg-white text-emerald-950 hover:bg-emerald-100",
        secondaryLink: "text-white hover:text-emerald-200",
        defaultHeadline: "Let’s build outside the walls.",
        defaultSub:
            "Outdoor living spaces designed for the Pacific Northwest—decks, patios, pergolas, and more.",
        defaultCtaOne: "Get a Project Estimate",
        defaultCtaOneHref: "/contact",
        defaultCtaTwo: "See Outdoor Projects",
        defaultCtaTwoHref: "/portfolio?service=outdoor-living",
    },
} as const;

const p = presets[category] ?? presets.interior;

// Allow forcing variant if you want later
const isDark = variant ? variant === "dark" : true;

const bgClass = isDark ? p.bg : "bg-gray-50";
const headingClass = isDark ? p.heading : "text-gray-900";
const subClass = isDark ? p.sub : "text-gray-600";
const primaryBtnClass = isDark
    ? p.primaryBtn
    : "bg-indigo-600 text-white hover:bg-indigo-500";
const secondaryLinkClass = isDark
    ? p.secondaryLink
    : "text-gray-900 hover:text-gray-700";

const finalHeadline = headline ?? p.defaultHeadline;
const finalSub = ctaSubheader ?? p.defaultSub;
const finalCtaOne = ctaOne ?? p.defaultCtaOne;
const finalCtaOneHref = ctaOneHref ?? p.defaultCtaOneHref;
const finalCtaTwo = ctaTwo ?? p.defaultCtaTwo;
const finalCtaTwoHref = ctaTwoHref ?? p.defaultCtaTwoHref;
---

<section class:list={[bgClass, "my-12"]}>
    <div
        class:list={[
            "mx-auto max-w-7xl px-6 py-20 lg:flex lg:items-center lg:justify-between lg:px-8",
            className,
        ]}
    >
        <div class="max-w-2xl">
            <h2
                class:list={[
                    "text-4xl font-semibold tracking-tight text-balance sm:text-5xl",
                    headingClass,
                ]}
            >
                {finalHeadline}
            </h2>
            <p class:list={["mt-4 text-lg leading-relaxed", subClass]}>
                {finalSub}
            </p>
        </div>

        <div class="mt-10 flex items-center gap-x-6 lg:mt-0 lg:shrink-0">
            <a
                href={finalCtaOneHref}
                class:list={[
                    "rounded-md px-5 py-3 text-sm font-semibold shadow-sm transition focus-visible:outline-2 focus-visible:outline-offset-2",
                    primaryBtnClass,
                ]}
            >
                {finalCtaOne}
            </a>

            <a
                href={finalCtaTwoHref}
                class:list={[
                    "text-sm font-semibold transition",
                    secondaryLinkClass,
                ]}
            >
                {finalCtaTwo}<span aria-hidden="true"> →</span>
            </a>
        </div>
    </div>
</section>
