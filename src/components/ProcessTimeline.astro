---
const { className } = Astro.props;
---

<div class:list={["bg-gray-50 py-16", className]}>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <h2 class="mt-6 text-lg/8 font-semibold tracking-tight text-gray-900 pb-6">
      Our Process
    </h2>
    <div
      class="mx-auto grid max-w-2xl grid-cols-1 gap-8 overflow-hidden lg:mx-0 lg:max-w-none lg:grid-cols-4"
    >
      <div>
        <span class="flex items-center text-sm/6 font-semibold text-indigo-600">
          <svg
            viewBox="0 0 4 4"
            aria-hidden="true"
            class="mr-4 size-1 flex-none"
          >
            <circle r="2" cx="2" cy="2" fill="currentColor"></circle>
          </svg>
          Consultation & Site Visit
          <div
            aria-hidden="true"
            class="absolute -ml-2 h-px w-screen -translate-x-full bg-gray-900/10 sm:-ml-4 lg:static lg:-mr-6 lg:ml-8 lg:w-auto lg:flex-auto lg:translate-x-0"
          >
          </div>
        </span>
        <p class="mt-1 text-base/7 text-gray-600">
          We review your goals, space, and budget and answer initial questions.
        </p>
      </div>
      <div>
        <span class="flex items-center text-sm/6 font-semibold text-indigo-600">
          <svg
            viewBox="0 0 4 4"
            aria-hidden="true"
            class="mr-4 size-1 flex-none"
          >
            <circle r="2" cx="2" cy="2" fill="currentColor"></circle>
          </svg>
          Estimate & Scope Review
          <div
            aria-hidden="true"
            class="absolute -ml-2 h-px w-screen -translate-x-full bg-gray-900/10 sm:-ml-4 lg:static lg:-mr-6 lg:ml-8 lg:w-auto lg:flex-auto lg:translate-x-0"
          >
          </div>
        </span>

        <p class="mt-1 text-base/7 text-gray-600">
          You receive a clear, written estimate with defined scope and
          expectations.
        </p>
      </div>
      <div>
        <span class="flex items-center text-sm/6 font-semibold text-indigo-600">
          <svg
            viewBox="0 0 4 4"
            aria-hidden="true"
            class="mr-4 size-1 flex-none"
          >
            <circle r="2" cx="2" cy="2" fill="currentColor"></circle>
          </svg>
          Build Phase
          <div
            aria-hidden="true"
            class="absolute -ml-2 h-px w-screen -translate-x-full bg-gray-900/10 sm:-ml-4 lg:static lg:-mr-6 lg:ml-8 lg:w-auto lg:flex-auto lg:translate-x-0"
          >
          </div>
        </span>
        <p class="mt-1 text-base/7 text-gray-600">
          We coordinate trades, manage permits if required, and keep the site
          clean and organized.
        </p>
      </div>
      <div>
        <span class="flex items-center text-sm/6 font-semibold text-indigo-600">
          <svg
            viewBox="0 0 4 4"
            aria-hidden="true"
            class="mr-4 size-1 flex-none"
          >
            <circle r="2" cx="2" cy="2" fill="currentColor"></circle>
          </svg>
          Final Walkthrough
          <div
            aria-hidden="true"
            class="absolute -ml-2 h-px w-screen -translate-x-full bg-gray-900/10 sm:-ml-4 lg:static lg:-mr-6 lg:ml-8 lg:w-auto lg:flex-auto lg:translate-x-0"
          >
          </div>
        </span>

        <p class="mt-1 text-base/7 text-gray-600">
          We review details with you and make sure everything is completed
          properly.
        </p>
      </div>
    </div>
  </div>
</div>
