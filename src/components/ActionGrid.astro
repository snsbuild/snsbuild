---
interface ActionItem {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { items } = Astro.props as { items: ActionItem[] };
---

<section class="mx-auto max-w-7xl py-24 px-6 lg:px-8">
  <h2 class="text-2xl font-bold tracking-tight text-gray-900 py-8">
    Jump to Section
  </h2>

  <div
    class="divide-y divide-gray-200 overflow-hidden rounded-lg bg-gray-200 shadow-sm sm:grid sm:grid-cols-2 sm:divide-y-0"
  >
    {
      items.map((action) => {
        return (
          <div class="group relative rounded-tl-lg rounded-tr-lg border-gray-200 bg-white p-6 focus-within:outline-2 focus-within:-outline-offset-2 focus-within:outline-indigo-600 sm:rounded-tr-none sm:odd:not-nth-last-2:border-b sm:even:border-l sm:even:not-last:border-b">
            <div>
              <i class:list={[action.icon, "text-indigo-500"]} />
            </div>
            <div class="mt-8">
              <h3 class="text-base font-semibold text-gray-900">
                <a href={action.href} class="focus:outline-hidden">
                  <span aria-hidden="true" class="absolute inset-0" />
                  {action.title}
                </a>
              </h3>
              <p class="mt-2 text-sm text-gray-500">{action.description}</p>
            </div>
            <span
              aria-hidden="true"
              class="pointer-events-none absolute top-6 right-6 text-gray-300 group-hover:text-gray-400"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="size-6">
                <path d="M20 4h1a1 1 0 00-1-1v1zm-1 12a1 1 0 102 0h-2zM8 3a1 1 0 000 2V3zM3.293 19.293a1 1 0 101.414 1.414l-1.414-1.414zM19 4v12h2V4h-2zm1-1H8v2h12V3zm-.707.293l-16 16 1.414 1.414 16-16-1.414-1.414z" />
              </svg>
            </span>
          </div>
        );
      })
    }
  </div>
</section>
