---
import type { Testimonial } from "../../types/content-types";
import Horse from "../Horse.astro";

interface Props {
  testimonial: Testimonial;
}

const {
  testimonial: { quote, author, neighborhood, rating },
} = Astro.props;
---

<section class="relative isolate bg-white px-6 py-24 sm:py-32 lg:px-8">
  <Horse
    class="absolute inset-0 m-auto h-125 w-125 text-indigo-100 opacity-40 -z-10"
    aria-hidden="true"
  />
  <figure class="mx-auto max-w-2xl">
    <p class="sr-only">5 out of 5 stars</p>
    <div class="flex gap-x-1 text-indigo-600">
      {
        Array.from({ length: rating }, () => (
          <svg
            viewBox="0 0 20 20"
            fill="currentColor"
            data-slot="icon"
            aria-hidden="true"
            class="size-5 flex-none"
          >
            <path
              d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401Z"
              clip-rule="evenodd"
              fill-rule="evenodd"
            />
          </svg>
        ))
      }
    </div>
    <blockquote
      class="mt-10 text-xl/8 font-semibold tracking-tight text-gray-900 sm:text-2xl/9"
    >
      <p>
        {quote}
      </p>
    </blockquote>
    <figcaption class="mt-10 flex items-center gap-x-6">
      <div class="text-sm/6">
        <div class="font-semibold text-gray-900">{author}</div>
        <div class="mt-0.5 text-gray-600">{neighborhood}</div>
      </div>
    </figcaption>
  </figure>
</section>
