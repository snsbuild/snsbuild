---
const serviceAreas = [
    // Seattle
    "Seattle",
    "Ballard",
    "Fremont",
    "Greenwood",
    "Phinney Ridge",
    "Wallingford",
    "Queen Anne",
    "Magnolia",
    "Capitol Hill",
    "Madison Park",
    "West Seattle",
    "Beacon Hill",
    "Columbia City",
    "Rainier Valley",
    "Northgate",

    // North Seattle & North King County
    "Shoreline",
    "Lake Forest Park",
    "Kenmore",
    "Bothell",
    "Mountlake Terrace",

    // Eastside
    "Bellevue",
    "Kirkland",
    "Redmond",
    "Sammamish",
    "Issaquah",
    "Mercer Island",
    "Newcastle",

    // South King County
    "Renton",
    "Kent",
    "Tukwila",
    "Burien",
    "SeaTac",
    "Des Moines",
    "Federal Way",
    "Covington",
    "Maple Valley",
    "Auburn",

    // Snohomish County
    "Lynnwood",
    "Edmonds",
    "Mukilteo",
    "Mill Creek",
    "Everett",
    "Marysville",
    "Lake Stevens",
    "Monroe",
];
---

<div class:list={["overflow-hidden bg-white py-24 sm:py-32"]}>
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div
            class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2"
        >
            <div class="lg:ml-auto lg:pt-4 lg:pl-4">
                <div class="lg:max-w-lg">
                    <h2 class="text-base/7 font-semibold text-indigo-600">
                        Service Areas
                    </h2>
                    <p
                        class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl"
                    >
                        Serving the Greater Seattle Area
                    </p>
                    <p class="mt-6 text-lg/8 text-gray-600">
                        From Snohomish to Federal Way, if you need help call
                        Saddle and Spur Construction today.
                    </p>
                    <dl
                        class="mt-10 grid grid-cols-[repeat(auto-fit,minmax(140px,1fr))] gap-3 text-sm"
                    >
                        {
                            serviceAreas.map((sa) => (
                                <div class="flex items-start gap-2">
                                    <i class="fa-solid fa-circle-check text-indigo-600 mt-1 text-xs" />
                                    <dt class="font-semibold text-gray-900">
                                        {sa}
                                    </dt>
                                </div>
                            ))
                        }
                    </dl>
                </div>
            </div>
            <div class="flex items-start justify-end lg:order-first">
                <img
                    width="2432"
                    height="1442"
                    src="service-area.png"
                    alt="Product screenshot"
                    class="w-3xl max-w-none rounded-xl shadow-xl ring-1 ring-gray-400/10 sm:w-228"
                />
            </div>
        </div>
    </div>
</div>
