---
type Testimonial = {
    name: string;
    neighborhood: string;
    projectType: string;
    rating: number;
    quote: string;
};

type Portfolio = {
    id: string;
    title: string;
    link: string;
    testimonials?: Testimonial[];
};

type CloudCard = {
    workId: string;
    workTitle: string;
    workLink: string;
    name: string;
    neighborhood: string;
    projectType: string;
    rating: number;
    quote: string;
};

import { markup, type PortfolioMarkup } from "../data/portfolio/index";

const stars = (rating: number) => "★".repeat(Math.max(0, Math.min(5, rating)));

function buildCards(markup: PortfolioMarkup[]): CloudCard[] {
    return markup.map((m) => {
        return {
            workId: m.id,
            workTitle: m.hero.kicker,
            workLink: m.link,
            name: m.name,
            neighborhood: m.neighborhood,
            projectType: m.projectType,
            ...m.testimonial,
        };
    });
}

function pickFeaturedAndCloud(cards: CloudCard[]) {
    if (!cards.length)
        return { featured: null as CloudCard | null, cloud: [] as CloudCard[] };

    // featured: longest quote tends to feel best visually
    const featured =
        cards
            .slice()
            .sort(
                (a, b) => (b.quote?.length ?? 0) - (a.quote?.length ?? 0),
            )[0] ?? cards[0];

    const nonFeatured = cards.filter((c) => c !== featured);

    const cloud: CloudCard[] = [];
    const src = nonFeatured.length ? nonFeatured : cards;
    for (let i = 0; cloud.length < 10; i++) {
        cloud.push(src[i % src.length]);
        if (src.length === 0) break;
    }

    return { featured, cloud };
}

const allCards = buildCards(markup);
const { featured, cloud } = pickFeaturedAndCloud(allCards);

const leftStack = cloud.slice(0, 3);
const midStack = cloud.slice(3, 5);
const rightTopStack = cloud.slice(5, 7);
const rightTallStack = cloud.slice(7, 10);
---

<section id="testimonials">
    <div class="relative isolate bg-white pt-24 pb-32 sm:pt-32">
        <div
            aria-hidden="true"
            class="absolute inset-x-0 top-1/2 -z-10 -translate-y-1/2 transform-gpu overflow-hidden opacity-30 blur-3xl"
        >
            <div
                style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"
                class="ml-[max(50%,38rem)] aspect-1313/771 w-328.25 bg-linear-to-tr from-[#ff80b5] to-[#9089fc]"
            >
            </div>
        </div>

        <div
            aria-hidden="true"
            class="absolute inset-x-0 top-0 -z-10 flex transform-gpu overflow-hidden pt-32 opacity-25 blur-3xl sm:pt-40 xl:justify-end"
        >
            <div
                style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"
                class="-ml-88 aspect-1313/771 w-328.25 flex-none origin-top-right rotate-30 bg-linear-to-tr from-[#ff80b5] to-[#9089fc] xl:mr-[calc(50%-12rem)] xl:ml-0"
            >
            </div>
        </div>

        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-2xl text-center">
                <h2 class="text-base/7 font-semibold text-indigo-600">
                    Testimonials
                </h2>
                <p
                    class="mt-2 text-4xl font-semibold tracking-tight text-balance text-gray-900 sm:text-5xl"
                >
                    See What Your Neighbors Have Been Saying About Us
                </p>
            </div>

            <div
                class="mx-auto mt-16 grid max-w-2xl grid-cols-1 grid-rows-1 gap-8 text-sm/6 text-gray-900 sm:mt-20 sm:grid-cols-2 xl:mx-0 xl:max-w-none xl:grid-flow-col xl:grid-cols-4"
            >
                <!-- FEATURED / LARGE CARD -->
                {
                    featured && (
                        <a
                            href={featured.workLink}
                            class="block rounded-2xl bg-white shadow-lg ring-1 ring-gray-900/5 transition hover:-translate-y-0.5 hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-indigo-600 sm:col-span-2 xl:col-start-2 xl:row-end-1"
                        >
                            <figure>
                                <blockquote class="p-6 text-lg font-semibold tracking-tight text-gray-900 sm:p-12 sm:text-xl/8">
                                    <p>“{featured.quote}”</p>
                                </blockquote>

                                <figcaption class="flex flex-wrap items-center gap-x-4 gap-y-1 border-t border-gray-900/10 px-6 py-4 sm:flex-nowrap">
                                    <div class="flex-auto">
                                        <div class="font-semibold text-gray-900">
                                            {featured.name}
                                        </div>
                                        <div class="text-gray-600">
                                            {featured.neighborhood} •{" "}
                                            {featured.projectType} •{" "}
                                            {stars(featured.rating)}
                                        </div>
                                    </div>
                                    <span class="text-indigo-600 font-semibold">
                                        View project →
                                    </span>
                                </figcaption>
                            </figure>
                        </a>
                    )
                }

                <!-- COLUMN GROUP 1 -->
                <div class="space-y-8 xl:contents xl:space-y-0">
                    <div class="space-y-8 xl:row-span-2">
                        {
                            leftStack.map((t) => (
                                <a
                                    href={t.workLink}
                                    class="block rounded-2xl bg-white p-6 shadow-lg ring-1 ring-gray-900/5 transition hover:-translate-y-0.5 hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-indigo-600"
                                >
                                    <figure>
                                        <blockquote class="text-gray-900">
                                            <p>“{t.quote}”</p>
                                        </blockquote>
                                        <figcaption class="mt-6">
                                            <div class="font-semibold text-gray-900">
                                                {t.name}
                                            </div>
                                            <div class="text-gray-600">
                                                {t.neighborhood} •{" "}
                                                {t.projectType} •{" "}
                                                {stars(t.rating)}
                                            </div>
                                        </figcaption>
                                    </figure>
                                </a>
                            ))
                        }
                    </div>

                    <div class="space-y-8 xl:row-start-1">
                        {
                            midStack.map((t) => (
                                <a
                                    href={t.workLink}
                                    class="block rounded-2xl bg-white p-6 shadow-lg ring-1 ring-gray-900/5 transition hover:-translate-y-0.5 hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-indigo-600"
                                >
                                    <figure>
                                        <blockquote class="text-gray-900">
                                            <p>“{t.quote}”</p>
                                        </blockquote>
                                        <figcaption class="mt-6">
                                            <div class="font-semibold text-gray-900">
                                                {t.name}
                                            </div>
                                            <div class="text-gray-600">
                                                {t.neighborhood} •{" "}
                                                {t.projectType} •{" "}
                                                {stars(t.rating)}
                                            </div>
                                        </figcaption>
                                    </figure>
                                </a>
                            ))
                        }
                    </div>
                </div>

                <!-- COLUMN GROUP 2 -->
                <div class="space-y-8 xl:contents xl:space-y-0">
                    <div class="space-y-8 xl:row-start-1">
                        {
                            rightTopStack.map((t) => (
                                <a
                                    href={t.workLink}
                                    class="block rounded-2xl bg-white p-6 shadow-lg ring-1 ring-gray-900/5 transition hover:-translate-y-0.5 hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-indigo-600"
                                >
                                    <figure>
                                        <blockquote class="text-gray-900">
                                            <p>“{t.quote}”</p>
                                        </blockquote>
                                        <figcaption class="mt-6">
                                            <div class="font-semibold text-gray-900">
                                                {t.name}
                                            </div>
                                            <div class="text-gray-600">
                                                {t.neighborhood} •{" "}
                                                {t.projectType} •{" "}
                                                {stars(t.rating)}
                                            </div>
                                        </figcaption>
                                    </figure>
                                </a>
                            ))
                        }
                    </div>

                    <div class="space-y-8 xl:row-span-2">
                        {
                            rightTallStack.map((t) => (
                                <a
                                    href={t.workLink}
                                    class="block rounded-2xl bg-white p-6 shadow-lg ring-1 ring-gray-900/5 transition hover:-translate-y-0.5 hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-indigo-600"
                                >
                                    <figure>
                                        <blockquote class="text-gray-900">
                                            <p>“{t.quote}”</p>
                                        </blockquote>
                                        <figcaption class="mt-6">
                                            <div class="font-semibold text-gray-900">
                                                {t.name}
                                            </div>
                                            <div class="text-gray-600">
                                                {t.neighborhood} •{" "}
                                                {t.projectType} •{" "}
                                                {stars(t.rating)}
                                            </div>
                                        </figcaption>
                                    </figure>
                                </a>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
