---
import Layout from "../layouts/Layout.astro";

const title = "404 — Page Not Found | Saddle and Spur Construction";
const description =
    "We couldn't find that page. Explore our remodeling services and recent projects in Seattle and King County.";
---

<Layout title={title} description={description}>
    <main class="mx-auto w-full max-w-7xl px-6 pt-10 pb-16 sm:pb-24 lg:px-8">
        <div class="mx-auto mt-20 max-w-2xl text-center sm:mt-24">
            <p class="text-base/8 font-semibold text-indigo-600">404</p>
            <h1
                class="mt-4 text-5xl font-semibold tracking-tight text-balance text-gray-900 sm:text-6xl"
            >
                This page does not exist
            </h1>
            <p
                class="mt-6 text-lg font-medium text-pretty text-gray-500 sm:text-xl/8"
            >
                Sorry, we couldn't find the page you're looking for.
            </p>
        </div>

        <div class="mx-auto mt-16 flow-root max-w-lg sm:mt-20">
            <h2 class="sr-only">Popular pages</h2>
            <ul
                role="list"
                class="-mt-6 divide-y divide-gray-900/5 border-b border-gray-900/5"
            >
                <li class="relative flex gap-x-6 py-6">
                    <div
                        class="flex size-10 flex-none items-center justify-center rounded-lg shadow-xs outline-1 outline-gray-900/10"
                    >
                        <!-- icon -->
                    </div>
                    <div class="flex-auto">
                        <h3 class="text-sm/6 font-semibold text-gray-900">
                            <a href="/services">
                                <span
                                    aria-hidden="true"
                                    class="absolute inset-0"></span>
                                Services
                            </a>
                        </h3>
                        <p class="mt-2 text-sm/6 text-gray-600">
                            See kitchen remodels, bathrooms, ADUs, additions,
                            and more.
                        </p>
                    </div>
                    <div class="flex-none self-center">
                        <!-- arrow icon -->
                    </div>
                </li>

                <li class="relative flex gap-x-6 py-6">
                    <div
                        class="flex size-10 flex-none items-center justify-center rounded-lg shadow-xs outline-1 outline-gray-900/10"
                    >
                        <!-- icon -->
                    </div>
                    <div class="flex-auto">
                        <h3 class="text-sm/6 font-semibold text-gray-900">
                            <a href="/portfolio">
                                <span
                                    aria-hidden="true"
                                    class="absolute inset-0"></span>
                                Portfolio
                            </a>
                        </h3>
                        <p class="mt-2 text-sm/6 text-gray-600">
                            Browse recent remodels and project stories across
                            Seattle and King County.
                        </p>
                    </div>
                    <div class="flex-none self-center">
                        <!-- arrow icon -->
                    </div>
                </li>

                <li class="relative flex gap-x-6 py-6">
                    <div
                        class="flex size-10 flex-none items-center justify-center rounded-lg shadow-xs outline-1 outline-gray-900/10"
                    >
                        <!-- icon -->
                    </div>
                    <div class="flex-auto">
                        <h3 class="text-sm/6 font-semibold text-gray-900">
                            <a href="/contact">
                                <span
                                    aria-hidden="true"
                                    class="absolute inset-0"></span>
                                Contact
                            </a>
                        </h3>
                        <p class="mt-2 text-sm/6 text-gray-600">
                            Request an estimate or ask a question about your
                            project.
                        </p>
                    </div>
                    <div class="flex-none self-center">
                        <!-- arrow icon -->
                    </div>
                </li>
            </ul>

            <div class="mt-10 flex justify-center">
                <a href="/" class="text-sm/6 font-semibold text-indigo-600">
                    <span aria-hidden="true">&larr;</span> Back to home
                </a>
            </div>
        </div>
    </main>
</Layout>
