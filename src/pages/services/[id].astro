---
import Layout from "../../layouts/Layout.astro";
import { kitchenRemodel } from "../../data/interior/kitchen-remodel";
import { buildSeoFrom } from "../../seo";
import ServiceFooter from "../../components/ServiceFooter.astro";
import CallToAction from "../../components/CallToAction.astro";
import ImageMosaic from "../../components/service/ImageMosaic.astro";
import Faq from "../../components/Faq.astro";
import ProcessTimeline from "../../components/ProcessTimeline.astro";
import SubServiceFeatures from "../../components/service/SubServiceFeatures.astro";
import BentoGrid from "../../components/BentoGrid.astro";
import ServiceShowHero from "../../components/hero/ServiceShowHero.astro";
import ServiceAreas from "../../components/ServiceAreas.astro";

export async function getStaticPaths() {
  return [{ params: { id: kitchenRemodel.id } }];
}

const { id } = Astro.params;
const page = kitchenRemodel;

const {
  show: {
    eyebrow,
    header,
    subheader,
    description,
    galleryImages,
    subServices,
    faqs,
    featuredTestimonial,
    relatedPortfolio,
  },
} = page;

const seo = buildSeoFrom(page);
---

<Layout {...seo}>
  <div class="relative isolate overflow-hidden bg-white py-16">
    <ServiceShowHero
      eyebrow={eyebrow}
      header={header}
      subheader={subheader}
      description={description}
      testimonial={featuredTestimonial}
    />

    <ImageMosaic images={galleryImages} />

    <SubServiceFeatures
      eyebrow={subServices.eyebrow}
      heading={subServices.heading}
      byline={subServices.byline}
      primaryCta={subServices.primaryCta}
      secondaryCta={subServices.secondaryCta}
      services={subServices.services}
    />

    <CallToAction />

    <BentoGrid
      eyebrow={relatedPortfolio.eyebrow}
      heading={relatedPortfolio.heading}
      cards={relatedPortfolio.cards}
    />
  </div>

  <ProcessTimeline />
  <ServiceAreas />
  <Faq faqs={faqs} />
  <ServiceFooter />
</Layout>
