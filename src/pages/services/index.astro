---
import Layout from "../../layouts/Layout.astro";
import ServiceFooter from "../../components/service/ServiceFooter.astro";
import ServiceList from "../../components/service/ServiceList.astro";
import CenteredWithBgImage from "../../components/header/CenteredWithBgImage.astro";
import ServiceCTA from "../../components/service/ServiceCTA.astro";

import { buildSeoFrom } from "../../seo";
import { filterByCategory, servicesIndex } from "../../data";
import { ServiceCategory } from "../../types/entity-types";

const seo = buildSeoFrom(servicesIndex);

const interiorCards = filterByCategory(ServiceCategory.Interior);
const outdoorCards = filterByCategory(ServiceCategory.Outdoor);
const expansionCards = filterByCategory(ServiceCategory.Expansion);
const structuralCards = filterByCategory(ServiceCategory.Structural);
---

<Layout {...seo}>
  <CenteredWithBgImage />

  <ServiceList
    cards={interiorCards}
    id="interior-services"
    category={"Interior Services"}
    cta={"Take a look at a kitchen we remodeled in Ballard"}
    ctaHref={"/portfolio/kitchen-remodel-ballard-seattle"}
  />

  <ServiceCTA category="interior" />

  <ServiceList
    cards={expansionCards}
    id="expansion-services"
    category={"Expansion Services"}
    cta={"Take a look at a kitchen we remodeled in Ballard"}
    ctaHref={"/portfolio/kitchen-remodel-ballard-seattle"}
  />

  <ServiceCTA category="expansion" />

  <ServiceList
    cards={outdoorCards}
    id="outdoor-living-services"
    category={"Outdoor Living Spaces"}
    cta={"Take a look at a kitchen we remodeled in Ballard"}
    ctaHref={"/portfolio/kitchen-remodel-ballard-seattle"}
  />

  <ServiceCTA category="outdoor" />

  <ServiceList
    cards={structuralCards}
    id="interior-services"
    category={"Structural Remodel"}
    cta={"Take a look at a kitchen we remodeled in Ballard"}
    ctaHref={"/portfolio/kitchen-remodel-ballard-seattle"}
  />

  <ServiceCTA category="interior" />

  <ServiceFooter />
</Layout>
