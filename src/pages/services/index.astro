---
import Layout from "../../layouts/Layout.astro";
import ServiceFooter from "../../components/service/ServiceFooter.astro";
import ServiceList from "../../components/service/ServiceList.astro";
import CenteredWithBgImage from "../../components/header/CenteredWithBgImage.astro";
import ServiceCTA from "../../components/service/ServiceCTA.astro";
import ActionGrid from "../../components/ActionGrid.astro";
import ServiceAreas from "../../components/service/ServiceAreas.astro";

import { buildSeoFrom } from "../../seo";
import { filterByCategory, servicesIndex } from "../../data";
import { ServiceCategory } from "../../types/entity-types";

const actions = [
  {
    title: "Indoor",
    description: "Kitchen, bath, and interior remodels.",
    href: "#interior-services",
    icon: "fa-solid fa-paint-roller",
  },
  {
    title: "Exterior",
    description: "Siding, windows, and exterior upgrades.",
    href: "#expansion-services",
    icon: "fa-solid fa-trowel-bricks",
  },
  {
    title: "Outdoor Living",
    description: "Decks, patios, and outdoor spaces.",
    href: "#outdoor-living-services",
    icon: "fa-solid fa-archway",
  },
  {
    title: "AUD / Expansion",
    description: "Accessory dwelling units and home expansions.",
    href: "#expansion-services",
    icon: "fa-solid fa-house-chimney",
  },
];

const seo = buildSeoFrom(servicesIndex);

const interiorCards = filterByCategory(ServiceCategory.Interior);
const cards = [
  ...interiorCards,
  ...interiorCards,
  ...interiorCards,
  ...interiorCards,
  ...interiorCards,
  ...interiorCards,
];
---

<Layout {...seo}>
  <CenteredWithBgImage />

  <ActionGrid items={actions} />

  <ServiceList
    cards={cards}
    id="interior-services"
    category={"Interior Services"}
    cta={"Take a look at a kitchen we remodeled in Ballard"}
    ctaHref={"/portfolio/kitchen-remodel-ballard-seattle"}
  />

  <ServiceCTA category="interior" />

  <ServiceAreas />
  <ServiceFooter />
</Layout>
