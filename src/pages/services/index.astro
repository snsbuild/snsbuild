---
import Layout from "../../layouts/Layout.astro";
import RequestEstimate from "../../components/RequestEstimate.astro";
---

<Layout title="Services | SNS Contracting">
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-12">Our Services</h1>

      <div class="grid md:grid-cols-2 gap-8">
        <a
          href="/services/kitchen-remodeling-seattle"
          class="p-8 border rounded-lg hover:shadow-lg transition"
        >
          <h2 class="text-2xl font-bold mb-3">Kitchen Remodeling</h2>
          <p class="text-gray-600 mb-4">
            Transform your kitchen with modern design, quality materials, and
            expert installation.
          </p>
          <p class="text-blue-700 font-semibold">Learn more →</p>
        </a>
        <a
          href="/services/bathroom-remodeling-seattle"
          class="p-8 border rounded-lg hover:shadow-lg transition"
        >
          <h2 class="text-2xl font-bold mb-3">Bathroom Remodeling</h2>
          <p class="text-gray-600 mb-4">
            Create your dream bathroom with custom fixtures, tile work, and
            thoughtful design.
          </p>
          <p class="text-blue-700 font-semibold">Learn more →</p>
        </a>
        <a
          href="/services/condo-remodeling-seattle"
          class="p-8 border rounded-lg hover:shadow-lg transition"
        >
          <h2 class="text-2xl font-bold mb-3">Condo Remodeling</h2>
          <p class="text-gray-600 mb-4">
            Specialized expertise in condo renovations with attention to
            building codes and HOA requirements.
          </p>
          <p class="text-blue-700 font-semibold">Learn more →</p>
        </a>
        <a
          href="/services/small-home-remodels-seattle"
          class="p-8 border rounded-lg hover:shadow-lg transition"
        >
          <h2 class="text-2xl font-bold mb-3">Small Home Remodels</h2>
          <p class="text-gray-600 mb-4">
            Maximize space and functionality with smart design solutions for
            smaller homes.
          </p>
          <p class="text-blue-700 font-semibold">Learn more →</p>
        </a>
        <a
          href="/services/decks-exterior-seattle"
          class="p-8 border rounded-lg hover:shadow-lg transition"
        >
          <h2 class="text-2xl font-bold mb-3">Decks & Exterior</h2>
          <p class="text-gray-600 mb-4">
            Build beautiful outdoor spaces with premium materials and expert
            craftsmanship.
          </p>
          <p class="text-blue-700 font-semibold">Learn more →</p>
        </a>
      </div>

      <RequestEstimate />
    </div>
  </section>
</Layout>
