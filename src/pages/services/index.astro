---
import Layout from "../../layouts/Layout.astro";
import ServiceFooter from "../../components/service/ServiceFooter.astro";
import ServiceList from "../../components/service/ServiceList.astro";
import CenteredWithBgImage from "../../components/header/CenteredWithBgImage.astro";
import ServiceCTA from "../../components/service/ServiceCTA.astro";

import { buildSeoFrom } from "../../seo";
import { filterByCategory, servicesIndex } from "../../data";
import { ServiceCategory } from "../../types/entity-types";

const seo = buildSeoFrom(servicesIndex);

const interiorCards = filterByCategory(ServiceCategory.Interior);
const outdoorCards = filterByCategory(ServiceCategory.Outdoor);
const expansionCards = filterByCategory(ServiceCategory.Expansion);
const structuralCards = filterByCategory(ServiceCategory.Structural);

const interiorFeatured = interiorCards.find((c) => c.homePageFeatured);
const outdoorFeatured = outdoorCards.find((c) => c.homePageFeatured);
const expansionFeatured = expansionCards.find((c) => c.homePageFeatured);
const structuralFeatured = structuralCards.find((c) => c.homePageFeatured);
---

<Layout {...seo}>
  <CenteredWithBgImage />

  <ServiceList
    cards={interiorCards}
    id="interior-services"
    category={"Interior Services"}
    cta={`See the kitchen we remodeled in ${interiorFeatured?.neighborhood}`}
    ctaHref={interiorFeatured?.featuredPortfolioHref ?? "/portfolio"}
  />

  <ServiceList
    cards={expansionCards}
    id="expansion-services"
    category={"Expansion Services"}
    cta={`See the ADU we built in ${expansionFeatured?.neighborhood}`}
    ctaHref={expansionFeatured?.featuredPortfolioHref ?? "/portfolio"}
  />

  <ServiceCTA category="expansion" />

  <ServiceList
    cards={outdoorCards}
    id="outdoor-living-services"
    category={"Outdoor Living Spaces"}
    cta={`See the covered deck we built in ${outdoorFeatured?.neighborhood}`}
    ctaHref={outdoorFeatured?.featuredPortfolioHref ?? "/portfolio"}
  />

  <ServiceList
    cards={structuralCards}
    id="structural-services"
    category={"Structural Remodel"}
    cta={`See the seismic retrofit we completed in ${structuralFeatured?.neighborhood}`}
    ctaHref={structuralFeatured?.featuredPortfolioHref ?? "/portfolio"}
  />

  <ServiceFooter />
</Layout>
