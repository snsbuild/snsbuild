---
import Layout from "../../layouts/Layout.astro";
import RequestEstimate from "../../components/RequestEstimate.astro";
---

<Layout title="Condo Remodeling in Seattle | SNS Contracting">
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-6">Condo Remodeling in Seattle</h1>

      <div class="prose max-w-none">
        <p class="text-lg text-gray-600 mb-6">
          Specialized expertise in condo and apartment renovations. We navigate
          HOA requirements and building codes to deliver seamless remodels in
          multi-unit buildings.
        </p>

        <h2 class="text-2xl font-bold mt-8 mb-4">Condo Remodeling Expertise</h2>
        <ul class="space-y-2 mb-6">
          <li class="text-gray-700">✓ HOA approval navigation</li>
          <li class="text-gray-700">✓ Shared wall considerations</li>
          <li class="text-gray-700">✓ Parking and access coordination</li>
          <li class="text-gray-700">✓ Sound and vibration management</li>
          <li class="text-gray-700">
            ✓ Utility upgrades within condo restrictions
          </li>
          <li class="text-gray-700">✓ Minimal disruption to neighbors</li>
        </ul>

        <h2 class="text-2xl font-bold mt-8 mb-4">Why We're Different</h2>
        <p class="text-gray-700 mb-6">
          Condo remodeling requires unique knowledge. We've successfully
          completed dozens of condo projects in Seattle and know how to work
          within HOA guidelines, manage shared spaces, and communicate
          effectively with building management.
        </p>
      </div>

      <RequestEstimate heading="Ready to upgrade your condo?" />

      <div class="mt-8 text-center">
        <a href="/services" class="text-blue-700 hover:text-blue-900"
          >← Back to Services</a
        >
      </div>
    </div>
  </section>
</Layout>
