---
import Layout from "../../layouts/Layout.astro";
import RequestEstimate from "../../components/RequestEstimate.astro";
---

<Layout title="Small Home Remodels in Seattle | SNS Contracting">
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-6">Small Home Remodels in Seattle</h1>

      <div class="prose max-w-none">
        <p class="text-lg text-gray-600 mb-6">
          Make the most of your smaller home with smart design and expert
          construction. We specialize in maximizing space and functionality in
          cozy Seattle homes.
        </p>

        <h2 class="text-2xl font-bold mt-8 mb-4">Small Space Solutions</h2>
        <ul class="space-y-2 mb-6">
          <li class="text-gray-700">✓ Space-maximizing design</li>
          <li class="text-gray-700">✓ Storage solutions and built-ins</li>
          <li class="text-gray-700">✓ Open concept conversions</li>
          <li class="text-gray-700">✓ Multi-functional spaces</li>
          <li class="text-gray-700">✓ Lighting to enhance perceived space</li>
          <li class="text-gray-700">✓ Efficient workflow design</li>
        </ul>

        <h2 class="text-2xl font-bold mt-8 mb-4">
          Smart Remodeling for Small Homes
        </h2>
        <p class="text-gray-700 mb-6">
          Smaller homes are increasingly popular in Seattle. We understand the
          unique challenges and opportunities in remodeling small spaces. Our
          designs maximize functionality without sacrificing style.
        </p>
      </div>

      <RequestEstimate heading="Maximize your space" />

      <div class="mt-8 text-center">
        <a href="/services" class="text-blue-700 hover:text-blue-900"
          >← Back to Services</a
        >
      </div>
    </div>
  </section>
</Layout>
