---
import Layout from "../../layouts/Layout.astro";
import RequestEstimate from "../../components/RequestEstimate.astro";
---

<Layout title="Kitchen Remodeling in Seattle | SNS Contracting">
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-6">Kitchen Remodeling in Seattle</h1>

      <div class="prose max-w-none">
        <p class="text-lg text-gray-600 mb-6">
          Your kitchen is the heart of your home. We specialize in transforming
          outdated kitchens into beautiful, functional spaces that add value and
          enjoyment to your home.
        </p>

        <h2 class="text-2xl font-bold mt-8 mb-4">What We Offer</h2>
        <ul class="space-y-2 mb-6">
          <li class="text-gray-700">
            ✓ Custom cabinet design and installation
          </li>
          <li class="text-gray-700">
            ✓ Countertop materials: granite, quartz, butcher block
          </li>
          <li class="text-gray-700">✓ Backsplash tile work</li>
          <li class="text-gray-700">✓ Electrical and plumbing updates</li>
          <li class="text-gray-700">✓ Flooring installation</li>
          <li class="text-gray-700">✓ Modern appliance placement</li>
        </ul>

        <h2 class="text-2xl font-bold mt-8 mb-4">Why Choose Us?</h2>
        <p class="text-gray-700 mb-6">
          We have over 20 years of experience in kitchen remodeling. Our team
          works closely with you to understand your vision and deliver results
          that exceed expectations. We're committed to quality craftsmanship,
          on-time delivery, and transparent pricing.
        </p>
      </div>

      <RequestEstimate heading="Ready to remodel your kitchen?" />

      <div class="mt-8 text-center">
        <a href="/services" class="text-blue-700 hover:text-blue-900"
          >← Back to Services</a
        >
      </div>
    </div>
  </section>
</Layout>
