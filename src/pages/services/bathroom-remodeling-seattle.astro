---
import Layout from "../../layouts/Layout.astro";
import RequestEstimate from "../../components/RequestEstimate.astro";
---

<Layout title="Bathroom Remodeling in Seattle | SNS Contracting">
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-6">Bathroom Remodeling in Seattle</h1>

      <div class="prose max-w-none">
        <p class="text-lg text-gray-600 mb-6">
          Create your dream bathroom with our expert remodeling services. From
          spa-like features to functional upgrades, we'll design a space you'll
          love.
        </p>

        <h2 class="text-2xl font-bold mt-8 mb-4">Services Include</h2>
        <ul class="space-y-2 mb-6">
          <li class="text-gray-700">✓ Vanity and cabinet customization</li>
          <li class="text-gray-700">✓ Tile installation and design</li>
          <li class="text-gray-700">
            ✓ Fixture upgrades (tubs, showers, toilets)
          </li>
          <li class="text-gray-700">✓ Waterproofing and moisture management</li>
          <li class="text-gray-700">✓ Lighting and ventilation</li>
          <li class="text-gray-700">✓ Accessibility upgrades</li>
        </ul>

        <h2 class="text-2xl font-bold mt-8 mb-4">Our Approach</h2>
        <p class="text-gray-700 mb-6">
          We understand that bathrooms require careful attention to detail,
          especially when it comes to water management and building code
          compliance. Our experienced team ensures your renovation is both
          beautiful and built to last.
        </p>
      </div>

      <RequestEstimate heading="Transform your bathroom" />

      <div class="mt-8 text-center">
        <a href="/services" class="text-blue-700 hover:text-blue-900"
          >← Back to Services</a
        >
      </div>
    </div>
  </section>
</Layout>
