---
import Layout from "../../layouts/Layout.astro";
import RequestEstimate from "../../components/RequestEstimate.astro";
---

<Layout title="Decks & Exterior Remodeling in Seattle | SNS Contracting">
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-6">Decks & Exterior Remodeling</h1>

      <div class="prose max-w-none">
        <p class="text-lg text-gray-600 mb-6">
          Expand your living space with beautiful outdoor areas. From decks to
          patios, we create stunning exterior spaces that complement your home
          and enhance your lifestyle.
        </p>

        <h2 class="text-2xl font-bold mt-8 mb-4">Exterior Services</h2>
        <ul class="space-y-2 mb-6">
          <li class="text-gray-700">✓ Custom deck design and construction</li>
          <li class="text-gray-700">✓ Patio and hardscape installation</li>
          <li class="text-gray-700">✓ Siding and exterior finishes</li>
          <li class="text-gray-700">✓ Roofing work</li>
          <li class="text-gray-700">✓ Outdoor kitchens and built-ins</li>
          <li class="text-gray-700">✓ Landscaping integration</li>
        </ul>

        <h2 class="text-2xl font-bold mt-8 mb-4">
          Quality Materials & Craftsmanship
        </h2>
        <p class="text-gray-700 mb-6">
          We use premium materials built to withstand Seattle's climate. Our
          attention to detail ensures your outdoor spaces are not only beautiful
          but durable and low-maintenance for years to come.
        </p>
      </div>

      <RequestEstimate heading="Create your outdoor oasis" />

      <div class="mt-8 text-center">
        <a href="/services" class="text-blue-700 hover:text-blue-900"
          >← Back to Services</a
        >
      </div>
    </div>
  </section>
</Layout>
