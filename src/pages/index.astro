---
import Layout from "../layouts/Layout.astro";

import HomeHero from "../components/home/HomeHero.astro";
import HomeCta from "../components/home/HomeCta.astro";
import HomeFeatures from "../components/home/HomeFeatures.astro";

import RequestEstimate from "../components/RequestEstimate.astro";
import HomeTestimonialCloud from "../components/home/HomeTestimonialCloud.astro";
import ServiceList from "../components/service/ServiceList.astro";
import { homePageFeaturedServices } from "../data";
import ServiceAreas from "../components/service/ServiceAreas.astro";
import type { PortfolioIndexCard } from "../types/entity-types";

const homeFeatured = homePageFeaturedServices();
const cards: PortfolioIndexCard[] = [...homeFeatured, ...homeFeatured, ...homeFeatured];
---

<Layout title="Saddle & Spur Construction">
  <HomeHero />
  <RequestEstimate />
  <HomeFeatures />

  <ServiceList
    cards={cards}
    category="Featured Services"
    cta="Find the Right Service"
    ctaHref="/services"
  />

  <ServiceAreas />

  <HomeTestimonialCloud />
  <HomeCta />
</Layout>
