---
import Layout from "../../../layouts/Layout.astro";
import { previousWorks } from "../../../data/previous-work";
import { getSeo } from "../../../utils/seo";
import { filterByTag, getAllTags } from "../../../utils/tags";

export async function getStaticPaths() {
    return getAllTags(previousWorks).map((tag) => ({
        params: { tag },
    }));
}

const { tag } = Astro.params;

const filtered = filterByTag(previousWorks, tag);

const site =
    Astro.site?.toString() ??
    (import.meta.env.DEV ? "http://localhost:4321" : undefined);

const title = `Previous Work: ${tag} | Saddle & Spur Construction`;
const description = `Browse our Seattle-area ${tag} projects—real work completed by Saddle & Spur Construction.`;

const seo = getSeo({
    site,
    page: {
        link: `/previous-work/tag/${tag}`,
        title,
        blurb: description,
        meta: {
            title,
            description,
            canonical: `/previous-work/tag/${tag}`,
            ogTitle: title,
            ogImage: "/images/og/previous-work.jpg",
        },
        schema: {
            "@context": "https://schema.org",
            "@type": "CollectionPage",
            name: title,
            description,
            url: `/previous-work/tag/${tag}`,
        },
    },
});

const currentTags = filtered.map((p) => p.tags);
---

<Layout {...seo}>
    <pre>
        {JSON.stringify(currentTags, undefined, 2)}
    </pre>
    <main class="mx-auto max-w-6xl px-4 py-12">
        <header class="mb-8">
            <a
                href="/previous-work"
                class="text-sm text-gray-600 hover:underline"
            >
                ← All projects
            </a>
            <h1 class="mt-2 text-3xl font-bold">Previous Work: {tag}</h1>
            <p class="mt-2 text-gray-600">{description}</p>
        </header>

        {
            filtered.length === 0 ? (
                <p class="text-gray-600">No projects found for “{tag}”.</p>
            ) : (
                <section class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
                    {filtered.map((p) => (
                        <a
                            href={p.link}
                            class="group block overflow-hidden rounded-xl border bg-white"
                        >
                            <div class="h-48 bg-gray-100">
                                <img
                                    src={p.imgSrc}
                                    alt={p.hero?.imageAlt ?? p.title}
                                    class="h-full w-full object-cover transition group-hover:scale-[1.02]"
                                    loading="lazy"
                                />
                            </div>
                            <div class="p-5">
                                <h2 class="text-lg font-bold">{p.title}</h2>
                                <p class="mt-2 text-sm text-gray-600">
                                    {p.blurb}
                                </p>
                                <div class="mt-4 flex flex-wrap gap-2">
                                    {p.tags.slice(0, 4).map((t) => (
                                        <span class="rounded-full bg-gray-100 px-2 py-1 text-xs text-gray-700">
                                            {t}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        </a>
                    ))}
                </section>
            )
        }
    </main>
</Layout>
