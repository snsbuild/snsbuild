---
import Layout from "../layouts/Layout.astro";
import RequestEstimateForm from "../components/RequestEstimateForm.astro";
---

<Layout title="Request Estimate | SNS Contracting">
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-6">Request an Estimate</h1>

      <p class="text-lg text-gray-600 mb-12">
        Contact us today for a free consultation and estimate. We're ready to
        discuss your project and answer any questions.
      </p>

      <RequestEstimateForm showContactInfo={true} />
    </div>
  </section>
</Layout>
