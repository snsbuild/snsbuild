---
import Layout from "../../layouts/Layout.astro";
import FormSelect from "../../components/FormSelect.astro";
import FormSearch from "../../components/FormSearch.astro";
import ServiceFooter from "../../components/ServiceFooter.astro";
import ServiceAreas from "../../components/ServiceAreas.astro";
import { portfolio, portfolioIndex } from "../../data";
import { buildSeoFrom } from "../../seo";

const uniq = (arr: string[]) => Array.from(new Set(arr.filter(Boolean)));

const serviceOptions = uniq(portfolio.map((p) => p.seo.project.serviceName));
const areaOptions = uniq(
  portfolio.map((p) => p.seo.project.location.neighborhood),
);

const slugify = (s: string) =>
  s
    .toLowerCase()
    .trim()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");

const serviceToSlug = new Map(serviceOptions.map((s) => [s, slugify(s)]));
const areaToSlug = new Map(areaOptions.map((s) => [s, slugify(s)]));

const seo = buildSeoFrom(portfolioIndex);
---

<Layout {...seo}>
  <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h1
        class="text-4xl font-semibold tracking-tight text-balance text-gray-900 sm:text-5xl"
      >
        Seattle Construction Portfolio
      </h1>
      <p class="mt-2 text-lg/8 text-gray-600">
        Filter by service and neighborhood to find relevant case studies.
      </p>
    </div>

    <!-- Filters -->
    <section class="mx-auto mt-10 max-w-3xl">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        <FormSelect id="filter-service" label="Service">
          <option value="">All services</option>
          {
            serviceOptions.map((label) => (
              <option value={serviceToSlug.get(label)}>{label}</option>
            ))
          }
        </FormSelect>

        <FormSelect id="filter-area" label="Neighborhood">
          <option value="">All areas</option>
          {
            areaOptions.map((label) => (
              <option value={areaToSlug.get(label)}>{label}</option>
            ))
          }
        </FormSelect>
        <FormSearch
          id="filter-q"
          label="Search"
          placeholder="Tile, curbless shower, ventilation…"
        />
      </div>

      <div class="mt-4 flex items-center justify-between text-sm">
        <p id="results-count" class="text-gray-600"></p>
        <button
          id="filters-clear"
          type="button"
          class="rounded-md bg-indigo-600 px-3.5 py-2.5 text-center text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600"
        >
          Clear filters
        </button>
      </div>
    </section>

    <!-- Grid -->
    <section class="mx-auto mt-14 max-w-2xl lg:mx-0 lg:max-w-none">
      <div
        id="portfolio-grid"
        class="grid grid-cols-1 gap-x-8 gap-y-16 lg:grid-cols-3"
      >
        {
          portfolio.map((p) => {
            const {
              seo: {
                title,
                description,
                keywords,
                project: {
                  name,
                  serviceName,
                  servicesPerformed,
                  location: { city, neighborhood },
                  materials,
                  testimonial,
                },
              },
              index: { card },
            } = p;

            const serviceSlug = serviceToSlug.get(serviceName);
            const areaSlug = areaToSlug.get(neighborhood);
            const searchable = [
              name,
              title,
              description,
              serviceName,
              neighborhood,
              city,
              ...keywords,
              ...servicesPerformed?.map((s) => s.name),
              ...servicesPerformed?.map((s) => s.description),
              ...materials,
            ]
              .filter(Boolean)
              .join(" ")
              .toLowerCase();

            return (
              <article
                class="portfolio-card flex flex-col"
                data-service={serviceSlug}
                data-area={areaSlug}
                data-search={searchable}
              >
                <a href={card.href} class="group block">
                  <div class="relative w-full">
                    <img
                      src={card.image.src}
                      alt={card.image.alt}
                      class="aspect-video w-full rounded-2xl bg-gray-100 object-fill sm:aspect-2/1 lg:aspect-3/2"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-gray-900/10" />
                  </div>

                  <div class="mt-6 flex items-center gap-x-3 text-xs">
                    <span class="rounded-full bg-gray-50 px-3 py-1.5 font-medium text-gray-600 ring-1 ring-inset ring-gray-900/5">
                      {serviceName}
                    </span>
                    <span class="text-gray-500">{neighborhood}</span>
                  </div>

                  <h2 class="mt-3 text-lg font-semibold leading-6 text-gray-900 group-hover:text-gray-600">
                    {name}
                  </h2>

                  <p class="mt-3 line-clamp-3 text-sm leading-6 text-gray-600">
                    {description}
                  </p>
                </a>

                <div class="mt-6">
                  <div>
                    <p class="text-sm text-gray-700 line-clamp-2">
                      <span class="mr-2 text-amber-500" aria-hidden="true">
                        {"★".repeat(
                          Math.max(
                            0,
                            Math.min(5, Math.round(testimonial.rating)),
                          ),
                        )}
                      </span>
                      <span class="sr-only">
                        {testimonial.rating} out of 5 stars.
                      </span>
                      “{testimonial.quote}”
                    </p>
                    <p class="mt-2 text-xs text-gray-500">
                      — {testimonial.author}
                    </p>
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>

      <p id="no-results" class="mt-10 hidden text-center text-sm text-gray-600">
        No projects match those filters.
      </p>
    </section>
  </div>
  <ServiceAreas />
  <ServiceFooter />
  <script is:inline>
    const $ = (sel) => document.querySelector(sel);

    const serviceEl = $("#filter-service");
    const areaEl = $("#filter-area");
    const qEl = $("#filter-q");
    const clearBtn = $("#filters-clear");
    const cards = Array.from(document.querySelectorAll(".portfolio-card"));
    const countEl = $("#results-count");
    const noResultsEl = $("#no-results");

    function getParams() {
      const url = new URL(window.location.href);
      return {
        service: url.searchParams.get("service") || "",
        area: url.searchParams.get("area") || "",
        q: url.searchParams.get("q") || "",
      };
    }

    function setParams(next) {
      const url = new URL(window.location.href);
      ["service", "area", "q"].forEach((k) => {
        if (next[k]) url.searchParams.set(k, next[k]);
        else url.searchParams.delete(k);
      });
      window.history.replaceState({}, "", url);
    }

    function applyFilters(fromUI = false) {
      const params = fromUI
        ? {
            service: serviceEl.value,
            area: areaEl.value,
            q: qEl.value.trim().toLowerCase(),
          }
        : (() => {
            const p = getParams();
            return {
              service: p.service,
              area: p.area,
              q: (p.q || "").trim().toLowerCase(),
            };
          })();

      if (!fromUI) {
        serviceEl.value = params.service;
        areaEl.value = params.area;
        qEl.value = params.q || "";
      } else {
        setParams(params);
      }

      let shown = 0;
      for (const card of cards) {
        const s = card.getAttribute("data-service") || "";
        const a = card.getAttribute("data-area") || "";
        const hay = (card.getAttribute("data-search") || "").toLowerCase();

        const okService = !params.service || params.service === s;
        const okArea = !params.area || params.area === a;
        const okQ = !params.q || hay.includes(params.q);

        const ok = okService && okArea && okQ;
        card.classList.toggle("hidden", !ok);
        if (ok) shown++;
      }

      countEl.textContent = `${shown} project${shown === 1 ? "" : "s"} shown`;
      noResultsEl.classList.toggle("hidden", shown !== 0);
    }

    serviceEl.addEventListener("change", () => applyFilters(true));
    areaEl.addEventListener("change", () => applyFilters(true));
    qEl.addEventListener("input", () => applyFilters(true));

    clearBtn.addEventListener("click", () => {
      serviceEl.value = "";
      areaEl.value = "";
      qEl.value = "";
      applyFilters(true);
    });

    applyFilters(false);
  </script>
</Layout>
