---
import Layout from "../layouts/Layout.astro";
import { previousWorks } from "../data/previous-work";
import { getSeo } from "../utils/seo";
import { getAllTags, filterByTag } from "../utils/tags";

// read query param (?tag=kitchen)
const selectedTag = Astro.url.searchParams.get("tag");

// filter
const filtered = filterByTag(previousWorks, selectedTag);

// tags for UI
const allTags = getAllTags(previousWorks);

// SEO for listing page (not a single project)
const site =
  Astro.site?.toString() ??
  (import.meta.env.DEV ? "http://localhost:4321" : undefined);

const title = selectedTag
  ? `Previous Work: ${selectedTag} | Saddle & Spur Construction`
  : "Previous Work | Saddle & Spur Construction";

const description = selectedTag
  ? `See our Seattle-area ${selectedTag} projects—real remodels and construction work completed by Saddle & Spur Construction.`
  : "Explore our previous remodeling and construction work across Seattle neighborhoods—kitchens, bathrooms, decks, and full home renovations.";

const seo = getSeo({
  site,
  page: {
    link: "/previous-work",
    title,
    blurb: description,
    meta: {
      title,
      description,
      canonical: "/previous-work",
      ogTitle: title,
      ogImage: "/images/og/previous-work.jpg", // pick a real image
    },
    // optional: listing schema (CollectionPage)
    schema: {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      name: title,
      description,
      url: "/previous-work",
    },
  },
});
---

<Layout {...seo}>
  <main class="mx-auto max-w-6xl px-4 py-12">
    <header class="mb-8">
      <h1 class="text-3xl font-bold">Previous Work</h1>
      <p class="mt-2 text-gray-600">
        {
          selectedTag ? (
            <>
              Filtered by: <span class="font-semibold">{selectedTag}</span>
            </>
          ) : (
            <>Browse recent projects across Seattle neighborhoods.</>
          )
        }
      </p>
    </header>

    <!-- Tag filter UI -->
    <section class="mb-10">
      <div class="flex flex-wrap gap-2">
        <a
          href="/previous-work"
          class={`rounded-full border px-3 py-1 text-sm ${
            !selectedTag
              ? "bg-gray-900 text-white"
              : "text-gray-700 hover:bg-gray-50"
          }`}
        >
          All
        </a>

        {
          allTags.map((tag) => (
            <a
              href={`/previous-work?tag=${encodeURIComponent(tag)}`}
              class={`rounded-full border px-3 py-1 text-sm ${
                selectedTag?.toLowerCase() === tag.toLowerCase()
                  ? "bg-gray-900 text-white"
                  : "text-gray-700 hover:bg-gray-50"
              }`}
            >
              {tag}
            </a>
          ))
        }
      </div>
    </section>

    <!-- Results -->

    <section
      aria-labelledby="featured-heading"
      class="relative mt-16 overflow-hidden rounded-lg lg:h-96"
    >
      <div class="absolute inset-0">
        <img
          src="https://tailwindcss.com/plus-assets/img/ecommerce-images/category-page-01-featured-collection.jpg"
          alt=""
          class="size-full object-cover"
        />
      </div>
      <div aria-hidden="true" class="relative h-96 w-full lg:hidden"></div>
      <div aria-hidden="true" class="relative h-32 w-full lg:hidden"></div>
      <div
        class="absolute inset-x-0 bottom-0 rounded-br-lg rounded-bl-lg bg-black/75 p-6 backdrop-blur-sm backdrop-filter sm:flex sm:items-center sm:justify-between lg:inset-x-auto lg:inset-y-0 lg:w-96 lg:flex-col lg:items-start lg:rounded-tl-lg lg:rounded-br-none"
      >
        <div>
          <h2 id="featured-heading" class="text-xl font-bold text-white">
            Workspace Collection
          </h2>
          <p class="mt-1 text-sm text-gray-300">
            Upgrade your desk with objects that keep you organized and
            clear-minded.
          </p>
        </div>
        <a
          href="#"
          class="mt-6 flex shrink-0 items-center justify-center rounded-md border border-white/25 px-4 py-3 text-base font-medium text-white hover:bg-white/10 sm:mt-0 sm:ml-8 lg:ml-0 lg:w-full"
          >View the collection</a
        >
      </div>
    </section>

    {
      filtered.length === 0 ? (
        <p class="text-gray-600">
          No projects found for <span class="font-semibold">{selectedTag}</span>
          . Try another tag.
        </p>
      ) : (
        filtered.map((p) => (
          <section
            aria-labelledby="featured-heading"
            class="relative mt-16 overflow-hidden rounded-lg lg:h-96"
          >
            <div class="absolute inset-0">
              <img src={p.imgSrc} alt={p.hero.imageAlt} loading="lazy" />
            </div>
            <div aria-hidden="true" class="relative h-96 w-full lg:hidden" />
            <div aria-hidden="true" class="relative h-32 w-full lg:hidden" />
            <div class="absolute inset-x-0 bottom-0 rounded-br-lg rounded-bl-lg bg-black/75 p-6 backdrop-blur-sm backdrop-filter sm:flex sm:items-center sm:justify-between lg:inset-x-auto lg:inset-y-0 lg:w-96 lg:flex-col lg:items-start lg:rounded-tl-lg lg:rounded-br-none">
              <div>
                <h2 id="featured-heading" class="text-xl font-bold text-white">
                  Workspace Collection
                </h2>
                <p class="mt-1 text-sm text-gray-300">
                  Upgrade your desk with objects that keep you organized and
                  clear-minded.
                </p>
              </div>
              <a
                href="#"
                class="mt-6 flex shrink-0 items-center justify-center rounded-md border border-white/25 px-4 py-3 text-base font-medium text-white hover:bg-white/10 sm:mt-0 sm:ml-8 lg:ml-0 lg:w-full"
              >
                View the collection
              </a>
            </div>
          </section>
        ))
      )
    }
  </main>
</Layout>

