---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Portfolio | SNS Contracting">
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-12">Previous Work</h1>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="border rounded-lg overflow-hidden">
          <div class="bg-gray-300 h-48 flex items-center justify-center">
            <span class="text-gray-500">Ballard Kitchen Remodel</span>
          </div>
          <div class="p-4">
            <h3 class="font-bold text-lg mb-2">Ballard Kitchen Remodel</h3>
            <p class="text-gray-600 text-sm">
              Complete kitchen renovation with custom cabinetry and quartz
              counters.
            </p>
          </div>
        </div>

        <div class="border rounded-lg overflow-hidden">
          <div class="bg-gray-300 h-48 flex items-center justify-center">
            <span class="text-gray-500">Queen Anne Bathroom</span>
          </div>
          <div class="p-4">
            <h3 class="font-bold text-lg mb-2">Queen Anne Bathroom</h3>
            <p class="text-gray-600 text-sm">
              Master bathroom upgrade with heated floors and spa-like features.
            </p>
          </div>
        </div>

        <div class="border rounded-lg overflow-hidden">
          <div class="bg-gray-300 h-48 flex items-center justify-center">
            <span class="text-gray-500">Green Lake Deck</span>
          </div>
          <div class="p-4">
            <h3 class="font-bold text-lg mb-2">Green Lake Deck</h3>
            <p class="text-gray-600 text-sm">
              20x16 pressure-treated deck with built-in seating and lighting.
            </p>
          </div>
        </div>

        <div class="border rounded-lg overflow-hidden">
          <div class="bg-gray-300 h-48 flex items-center justify-center">
            <span class="text-gray-500">Capitol Hill Condo</span>
          </div>
          <div class="p-4">
            <h3 class="font-bold text-lg mb-2">Capitol Hill Condo Remodel</h3>
            <p class="text-gray-600 text-sm">
              Full condo renovation including kitchen, bathroom, and flooring.
            </p>
          </div>
        </div>

        <div class="border rounded-lg overflow-hidden">
          <div class="bg-gray-300 h-48 flex items-center justify-center">
            <span class="text-gray-500">West Seattle Addition</span>
          </div>
          <div class="p-4">
            <h3 class="font-bold text-lg mb-2">West Seattle Addition</h3>
            <p class="text-gray-600 text-sm">
              Second-story addition with new master suite and bathroom.
            </p>
          </div>
        </div>

        <div class="border rounded-lg overflow-hidden">
          <div class="bg-gray-300 h-48 flex items-center justify-center">
            <span class="text-gray-500">Beacon Hill Kitchen</span>
          </div>
          <div class="p-4">
            <h3 class="font-bold text-lg mb-2">Beacon Hill Kitchen</h3>
            <p class="text-gray-600 text-sm">
              Open-concept kitchen renovation with island and new appliances.
            </p>
          </div>
        </div>
      </div>

      <div class="mt-12 p-8 bg-blue-700 text-white rounded-lg text-center">
        <h3 class="text-2xl font-bold mb-4">
          See what we can do for your home
        </h3>
        <a
          href="/contact"
          class="inline-block px-6 py-3 bg-white text-blue-700 font-bold rounded hover:bg-gray-100 transition"
        >
          Request Estimate
        </a>
      </div>
    </div>
  </section>
</Layout>
