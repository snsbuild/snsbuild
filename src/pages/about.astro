---
import Layout from "../layouts/Layout.astro";
import { buildSeoFrom } from "../seo";
import { phoneDisplay, phoneHref } from "../siteConfig";
import type { MarketingPage } from "../types/entity-types";

export const aboutPage: MarketingPage = {
  kind: "marketing",
  path: "/about",
  seo: {
    title: "About Saddle and Spur Construction | Seattle General Contractor",
    description:
      "Meet Saddle and Spur Construction — a Seattle-area general contractor focused on clear scopes, quality craftsmanship, and predictable timelines.",
    keywords: [
      "about saddle and spur construction",
      "seattle general contractor",
    ],
    ogImage: {
      src: "/images/og/about.jpg",
      alt: "Saddle and Spur Construction team",
    },
    images: [{ src: "/images/about/team.jpg", alt: "Team on site" }],
  },
  faqs: [
    {
      question: "Where do you work?",
      answer: "We serve Greater Seattle and King County.",
    },
    {
      question: "What types of projects do you take?",
      answer: "Kitchens, bathrooms, additions, and whole-home remodels.",
    },
  ],
};

const seo = buildSeoFrom(aboutPage);
---

<Layout
  title={seo.openGraph.title}
  description={seo.openGraph.description}
  canonical={seo.canonical}
  openGraph={seo.openGraph}
  jsonLd={seo.jsonLd}
>
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-6">About S&S Construction</h1>

      <div class="prose max-w-none">
        <p class="text-lg text-gray-600 mb-6">
          S&S Construction has been serving the Seattle area for over 20 years,
          specializing in residential remodeling that transforms homes and
          improves quality of life.
        </p>

        <h2 class="text-2xl font-bold mt-8 mb-4">Who We Are</h2>
        <p class="text-gray-700 mb-6">
          We're a team of licensed, insured contractors dedicated to delivering
          exceptional craftsmanship on every project. From initial consultation
          to final walkthrough, we maintain the highest standards of
          professionalism and quality.
        </p>

        <h2 class="text-2xl font-bold mt-8 mb-4">Our Commitment</h2>
        <ul class="space-y-2 mb-6">
          <li class="text-gray-700">✓ Licensed & Insured</li>
          <li class="text-gray-700">✓ Fair, transparent pricing</li>
          <li class="text-gray-700">✓ On-time project completion</li>
          <li class="text-gray-700">
            ✓ Open communication throughout the project
          </li>
          <li class="text-gray-700">✓ Warranty on all work</li>
          <li class="text-gray-700">✓ Respect for your home and schedule</li>
        </ul>

        <h2 class="text-2xl font-bold mt-8 mb-4">Serving the Seattle Area</h2>
        <p class="text-gray-700 mb-6">
          We proudly serve Seattle and surrounding neighborhoods including
          Ballard, Queen Anne, Capitol Hill, Green Lake, West Seattle, Beacon
          Hill, and Shoreline. Our deep knowledge of local building codes and
          neighborhood characteristics ensures your project meets all
          requirements while respecting your community.
        </p>

        <div class="bg-indigo-100 p-6 rounded-lg mt-8">
          <p class="text-lg mb-2">
            <strong>License:</strong> WA Contractor License #ABC123<br />
            <strong>Insured:</strong> Full general liability and workers compensation<br
            />
            <strong>Phone:</strong>
            <a href={`tel:${phoneHref}`} class="text-indigo-700"
              >{phoneDisplay}</a
            >
          </p>
        </div>
      </div>

      <div class="mt-12 p-8 bg-indigo-700 text-white rounded-lg text-center">
        <h3 class="text-2xl font-bold mb-4">Ready to work with us?</h3>
        <a
          href="/contact"
          class="inline-block px-6 py-3 bg-white text-indigo-700 font-bold rounded hover:bg-gray-100 transition"
        >
          Request Estimate
        </a>
      </div>
    </div>
  </section>
</Layout>
