---
import CallToAction from "../components/CallToAction.astro";
import Faq from "../components/Faq.astro";
import ProcessTimeline from "../components/ProcessTimeline.astro";
import ServiceAreas from "../components/service/ServiceAreas.astro";
import Layout from "../layouts/Layout.astro";
import { buildSeoFrom } from "../seo";
import { phoneDisplay, phoneHref, email, license } from "../siteConfig";
import type { MarketingPage } from "../types/entity-types";

export const aboutPage: MarketingPage = {
  kind: "marketing",
  path: "/about",
  seo: {
    title: "About Saddle and Spur Construction | Seattle General Contractor",
    description:
      "Meet Saddle and Spur Construction — a Seattle-area general contractor focused on clear scopes, quality craftsmanship, and predictable timelines.",
    keywords: [
      "about saddle and spur construction",
      "seattle general contractor",
    ],
    ogImage: {
      src: "/images/og/about.jpg",
      alt: "Saddle and Spur Construction team",
    },
    images: [{ src: "/images/about/team.jpg", alt: "Team on site" }],
  },
  faqs: [
    {
      question: "Where do you work?",
      answer:
        "We serve Greater Seattle and King County — from Ballard and Capitol Hill to Bellevue, Kirkland, and Sammamish.",
    },
    {
      question: "What types of projects do you take?",
      answer:
        "We handle a wide range of residential projects: kitchens, bathrooms, whole-home remodels, flooring, windows and doors, ADUs, additions, garage conversions, outdoor living spaces, and roofing and structural work.",
    },
    {
      question: "Are you licensed and bonded?",
      answer: `Yes. Saddle and Spur Construction is fully licensed and bonded in Washington State. Our contractor license is ${license}.`,
    },
    {
      question: "Do you pull permits?",
      answer:
        "Yes — we pull all required permits and handle inspections. Skipping permits creates problems at resale and puts your home at risk. We don't cut that corner.",
    },
    {
      question: "How do I get started?",
      answer:
        "Reach out through our contact page or give us a call. We'll schedule a site visit, walk through your goals, and put together a detailed scope and estimate.",
    },
  ],
};

const seo = buildSeoFrom(aboutPage);
---

<Layout
  title={seo.openGraph.title}
  description={seo.openGraph.description}
  canonical={seo.canonical}
  openGraph={seo.openGraph}
  jsonLd={seo.jsonLd}
>
  <div class="isolate">
    <!-- Hero section -->
    <div
      class="relative isolate -z-10 overflow-hidden bg-linear-to-b from-indigo-100/20 pt-14"
    >
      <div
        aria-hidden="true"
        class="absolute inset-y-0 right-1/2 -z-10 -mr-96 w-[200%] origin-top-right skew-x-[-30deg] bg-white shadow-xl ring-1 shadow-indigo-600/10 ring-indigo-50 sm:-mr-80 lg:-mr-96"
      >
      </div>
      <div class="mx-auto max-w-7xl px-6 pb-16 sm:pb-40 lg:px-8">
        <div
          class="mx-auto max-w-2xl lg:mx-0 lg:grid lg:max-w-none lg:grid-cols-2 lg:gap-x-16 lg:gap-y-8 xl:grid-cols-1 xl:grid-rows-1 xl:gap-x-8"
        >
          <h1
            class="max-w-2xl text-5xl font-semibold tracking-tight text-balance text-gray-900 sm:text-7xl lg:col-span-2 xl:col-auto"
          >
            Seattle residential remodeling, done right
          </h1>
          <div class="mt-6 max-w-xl lg:mt-0 xl:col-end-1 xl:row-start-1">
            <p
              class="text-lg font-medium text-pretty text-gray-500 sm:text-xl/8"
            >
              Saddle and Spur Construction is a Seattle-based general contractor
              focused exclusively on residential projects. We work across King
              County — handling everything from kitchen and bathroom remodels to
              ADUs, additions, and structural upgrades. Our job is to make your
              home better while keeping the process clear, honest, and on
              schedule.
            </p>
          </div>
          <img
            src="/images/about/gallery-1.jpg"
            alt="Remodeled home interior"
            class="mt-10 aspect-6/5 w-full max-w-lg rounded-2xl object-cover outline-1 -outline-offset-1 outline-black/5 sm:mt-16 lg:mt-0 lg:max-w-none xl:row-span-2 xl:row-end-2 xl:mt-36"
          />
        </div>
      </div>
      <div
        class="absolute inset-x-0 bottom-0 -z-10 h-24 bg-linear-to-t from-white sm:h-32"
      >
      </div>
    </div>

    <ProcessTimeline className="bg-white" />

    <!-- Our approach section -->
    <div class="mt-32 overflow-hidden sm:mt-40">
      <div class="mx-auto max-w-7xl px-6 lg:flex lg:px-8">
        <div
          class="mx-auto grid max-w-2xl grid-cols-1 gap-x-12 gap-y-16 lg:mx-0 lg:max-w-none lg:min-w-full lg:flex-none lg:gap-y-8"
        >
          <div class="lg:col-end-1 lg:w-full lg:max-w-lg lg:pb-8">
            <h2
              class="text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl"
            >
              Residential focus, start to finish
            </h2>
            <p class="mt-6 text-xl/8 text-gray-700">
              We work on homes — not commercial builds, not quick flips. That
              focus means our crews know residential construction inside and
              out, and our process is built around how people actually live
              during a remodel.
            </p>
            <p class="mt-6 text-base/7 text-gray-600">
              Every project starts with a detailed scope. Before any work
              begins, we walk through what's included, what decisions need to be
              made, and what the timeline looks like. No vague estimates, no
              surprise change orders for things we should have caught upfront.
              We pull permits, schedule inspections, and hand off a home that's
              built to last.
            </p>
          </div>
          <div
            class="flex flex-wrap items-start justify-end gap-6 sm:gap-8 lg:contents"
          >
            <div
              class="w-0 flex-auto lg:ml-auto lg:w-auto lg:flex-none lg:self-end"
            >
              <img
                src="/images/about/gallery-7.jpg"
                alt="Kitchen remodel in progress"
                class="aspect-7/5 w-148 max-w-none rounded-2xl bg-gray-50 object-cover max-sm:w-120"
              />
            </div>
            <div
              class="contents lg:col-span-2 lg:col-end-2 lg:ml-auto lg:flex lg:w-148 lg:items-start lg:justify-end lg:gap-x-8"
            >
              <div
                class="order-first flex w-64 flex-none justify-end self-end max-sm:w-40 lg:w-auto"
              >
                <img
                  src="/images/about/gallery-2.jpg"
                  alt="Contractor reviewing plans"
                  class="aspect-4/3 w-[24rem] max-w-none flex-none rounded-2xl bg-gray-50 object-cover"
                />
              </div>
              <div
                class="flex w-96 flex-auto justify-end lg:w-auto lg:flex-none"
              >
                <img
                  src="/images/about/gallery-4.jpg"
                  alt="Finished bathroom remodel"
                  class="aspect-7/5 w-148 max-w-none flex-none rounded-2xl bg-gray-50 object-cover max-sm:w-120"
                />
              </div>
              <div
                class="hidden sm:block sm:w-0 sm:flex-auto lg:w-auto lg:flex-none"
              >
                <img
                  src="/images/about/gallery-5.jpg"
                  alt="Outdoor deck construction"
                  class="aspect-4/3 w-[24rem] max-w-none rounded-2xl bg-gray-50 object-cover"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <CallToAction />
    <!-- Stats -->
    <div class="mx-auto mt-32 max-w-7xl px-6 pb-10 sm:mt-40 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <h2
          class="text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl"
        >
          Built for Seattle homeowners
        </h2>
        <p class="mt-6 text-base/7 text-gray-600">
          We're a local company — not a franchise, not a national chain. Every
          project is managed by people who know Seattle neighborhoods, Seattle
          inspectors, and Seattle weather.
        </p>
      </div>
      <div
        class="mx-auto mt-16 flex max-w-2xl flex-col gap-8 lg:mx-0 lg:mt-20 lg:max-w-none lg:flex-row lg:items-end"
      >
        <div
          class="flex flex-col-reverse justify-between gap-x-16 gap-y-8 rounded-2xl bg-gray-50 p-8 sm:w-3/4 sm:max-w-md sm:flex-row-reverse sm:items-end lg:w-72 lg:max-w-none lg:flex-none lg:flex-col lg:items-start"
        >
          <p class="flex-none text-3xl font-bold tracking-tight text-gray-900">
            12 +
          </p>
          <div class="sm:w-80 sm:shrink lg:w-auto lg:flex-none">
            <p class="text-lg font-semibold tracking-tight text-gray-900">
              Service specialties
            </p>
            <p class="mt-2 text-base/7 text-gray-600">
              From flooring and windows to ADUs and structural upgrades — one
              contractor for the full scope of your home.
            </p>
          </div>
        </div>
        <div
          class="flex flex-col-reverse justify-between gap-x-16 gap-y-8 rounded-2xl bg-gray-900 p-8 sm:flex-row-reverse sm:items-end lg:w-full lg:max-w-sm lg:flex-auto lg:flex-col lg:items-start lg:gap-y-44"
        >
          <p class="flex-none text-3xl font-bold tracking-tight text-white">
            100+
          </p>
          <div class="sm:w-80 sm:shrink lg:w-auto lg:flex-none">
            <p class="text-lg font-semibold tracking-tight text-white">
              Seattle-area homes remodeled
            </p>
            <p class="mt-2 text-base/7 text-gray-400">
              Projects across Ballard, Capitol Hill, Fremont, Bellevue,
              Sammamish, and beyond.
            </p>
          </div>
        </div>
        <div
          class="flex flex-col-reverse justify-between gap-x-16 gap-y-8 rounded-2xl bg-indigo-600 p-8 sm:w-11/12 sm:max-w-xl sm:flex-row-reverse sm:items-end lg:w-full lg:max-w-none lg:flex-auto lg:flex-col lg:items-start lg:gap-y-28"
        >
          <p class="flex-none text-3xl font-bold tracking-tight text-white">
            Permitted
          </p>
          <div class="sm:w-80 sm:shrink lg:w-auto lg:flex-none">
            <p class="text-lg font-semibold tracking-tight text-white">
              Every project, fully permitted
            </p>
            <p class="mt-2 text-base/7 text-indigo-200">
              We pull permits and pass inspections on every project that
              requires them — no shortcuts.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Faq faqs={aboutPage.faqs} />
  <ServiceAreas />
</Layout>
